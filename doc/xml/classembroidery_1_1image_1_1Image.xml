      <memberdef kind="function" id="classembroidery_1_1image_1_1Image_1aa39070e72d93f577313458cf37ac963a" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type>def</type>
        <definition>def embroidery.image.Image.draw</definition>
        <argsstring>(self, description)</argsstring>
        <name>draw</name>
        <qualifiedname>embroidery.image.Image.draw</qualifiedname>
        <param>
          <type>self</type>
          <defname>self</defname>
        </param>
        <param>
          <type>description</type>
          <defname>description</defname>
        </param>
        <briefdescription>
        </briefdescription>
        <detaileddescription>
<para><verbatim>This is similar to using an svg path, we can blend these systems
later.
int_buffer[4]
icon = 0
painter = 0
QPen pen
get_n_ints(description, int_buffer, 2)
icon = new QPixmap(int_buffer[0], int_buffer[1])
painter = new QPainter(icon)
pen.setWidth(10)
for ptr in description:
    # Other functions we can use are eraseRect, drawArc etc.
    # https://doc.qt.io/qt-5/qpainter.html
    if (strncmp(ptr, &quot;rect&quot;, 4)==0) {
        pen.setColor(Color(QRgb(0x000000)))
        painter.set_pen(pen)
        get_n_ints(ptr+5, int_buffer, 4)
        painter.fillRect(int_buffer[0], int_buffer[1],
            int_buffer[2], int_buffer[3], Qt_SolidPattern);</verbatim> </para>
        </detaileddescription>
        <inbodydescription>
        </inbodydescription>
